# Postgres (Airflow metadata)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.3-python3.11
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_secure
MINIO_ENDPOINT=http://localhost:9000

# Raw ingestion
RAW_SOURCE_DIR=data
RAW_BUCKET_NAME=raw-zone
RAW_MARKET_PATH=s3a://raw-zone/market_data

# Curated lake paths (Spark uses s3a://, DuckDB uses s3://)
CURATED_ROOT_PATH=s3a://curated-zone
CURATED_STAGING_ROOT=s3a://curated-zone/staging
CURATED_FACT_TRADES_PATH=s3://curated-zone/fact_trades/*/*.parquet

# Data quality thresholds
MIN_CURATED_FACT_ROWS=100

# Streamlit dashboard (use http://minio:9000 when running inside Docker Compose)
STREAMLIT_SERVER_PORT=8501
